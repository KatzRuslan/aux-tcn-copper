{
    "name": "aux-tcn-electron",
    "version": "1.0.0",
    "main": "dist/main.js",
    "scripts": {
        "build": "tsc",
        "start": "electron .",
        "dev": "cross-env NODE_ENV=development electron .",
        "package": "electron-builder --win --publish never"
    },
    "dependencies": {
        "axios": "^1.12.2",
        "exceljs": "^4.4.0"
    },
    "build": {
        "appId": "com.aux.tcn.copper",
        "productName": "Aux TCN Electron",
        "directories": {
            "output": ".."
        },
        "files": [
            "dist/**/*",
            "node_modules/**/*",
            "package.json"
        ],
        "win": {
            "target": "portable"
        },
        "extraResources": [
            { "from": "../public/schemes/border-radius.scheme.json", "to": "border-radius.scheme.json" },
            { "from": "../public/data/border-radius.data.json", "to": "border-radius.data.json" },
            { "from": "../public/schemes/color-palette.scheme.json", "to": "color-palette.scheme.json" },
            { "from": "../public/data/color-palette.data.json", "to": "color-palette.json" },
            { "from": "../public/schemes/semantic.scheme.json", "to": "semantic.scheme.json" },
            { "from": "../public/data/semantic.data.json", "to": "semantic.data.json" },
            { "from": "../public/configurations.json", "to": "configurations.json" }
        ]
    },
    "devDependencies": {
        "@types/axios": "^0.14.4",
        "@types/node": "^20.12.12",
        "cross-env": "^7.0.3",
        "electron": "^30.0.0",
        "electron-builder": "^26.8.1",
        "electron-devtools-installer": "^4.0.0",
        "ts-node": "^10.9.2",
        "typescript": "^5.6.0"
    }
}
