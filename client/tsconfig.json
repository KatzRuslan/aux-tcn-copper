/* To learn more about Typescript configuration file: https://www.typescriptlang.org/docs/handbook/tsconfig-json.html. */
/* To learn more about Angular compiler options: https://angular.dev/reference/configs/angular-compiler-options. */
{
    "compileOnSave": false,
    "compilerOptions": {
        "noImplicitOverride": true,
        "noPropertyAccessFromIndexSignature": true,
        "noImplicitReturns": true,
        "noFallthroughCasesInSwitch": true,
        "skipLibCheck": true,
        "isolatedModules": true,
        "experimentalDecorators": true,
        "importHelpers": true,
        "target": "ES2022",
        "module": "preserve",
        "paths": {
            // "@tcn-preset": ["./public/tcn-preset.json"],
            "@tcn-preset": ["../public/preset.json"],
            "@environments": ["./src/environments/environment"],
            "@shared-module": ["./src/app/shared/shared.module.ts"],
            "@shared-core-module": ["./src/app/shared/shared-core.module.ts"],
            "@helpers/*": ["./src/app/shared/helpers/*"],
            "@enums": ["./src/app/shared/enums/index.ts"],
            "@shared-components/*": ["./src/app/shared/components/*"],
            "@form-component": ["./src/app/shared/components/form-component/form-component.ts"],
            "@interfaces": ["./src/app/shared/interfaces/index.ts"],
            "@seed": ["./src/app/shared/seed-data/index.ts"],
            "@app-store": ["./src/app/store/app.store.ts"],
            "@app-helper": ["./src/app/store/app.helper.ts"],
            "@settings-store": ["./src/app/features/settings/store/settings.store.ts"],
            "@settings-helper": ["./src/app/features/settings/store/settings-store.helper.ts"],
            // "@templates-right": ["./src/app/features/templates/templates-right/templates-right.ts"]
            "@style-guide-store": ["./src/app/features/style-guide/store/style-guide.store.ts"],
            "@header-color-palette-right": ["./src/app/features/style-guide/sections/color-palette/header-right/header-right.ts"],
            "@header-ui-component-right": ["./src/app/features/style-guide/sections/ui-component/header-right/header-right.ts"],
        }
    },
    "angularCompilerOptions": {
        "enableI18nLegacyMessageIdFormat": false,
        "strictInjectionParameters": true,
        "strictInputAccessModifiers": true
    },
    "files": [],
    "references": [
        {
            "path": "./tsconfig.app.json"
        },
        {
            "path": "./tsconfig.spec.json"
        }
    ]
}
